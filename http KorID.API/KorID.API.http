@KorID.API_HostAddress = http://localhost:5222
@contentType = application/json

###
# Users - Get all
GET {{KorID.API_HostAddress}}/api/Users
Accept: {{contentType}}

###
# Users - Get by id
GET {{KorID.API_HostAddress}}/api/Users/1
Accept: {{contentType}}

###
# Users - Create
POST {{KorID.API_HostAddress}}/api/Users
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "id": 0,
  "userName": "jdoe",
  "email": "jdoe@example.com",
  "firstName": "John",
  "lastName": "Doe",
  "isActive": true
}

###
# Users - Update
PUT {{KorID.API_HostAddress}}/api/Users/1
Content-Type: {{contentType}}
Accept: {{contentType}}

{
  "id": 1,
  "userName": "jdoe",
  "email": "john.doe@example.com",
  "firstName": "John",
  "lastName": "Doe",
  "isActive": true
}

###
# Users - Delete
DELETE {{KorID.API_HostAddress}}/api/Users/1
Accept: {{contentType}}

###
# Organizations
GET {{KorID.API_HostAddress}}/api/Organizations
Accept: application/json

###
# Organizations - Get by id
GET {{KorID.API_HostAddress}}/api/Organizations/1
Accept: application/json

###
# Organizations - Create
POST {{KorID.API_HostAddress}}/api/Organizations
Content-Type: application/json
Accept: application/json

{
  "name": "Example Organization",
  "slug": "example-org"
}

###
# Organizations - Update
PUT {{KorID.API_HostAddress}}/api/Organizations/1
Content-Type: application/json
Accept: application/json

{
  "id": 1,
  "name": "Updated Organization",
  "slug": "updated-org"
}

###
# Organizations - Delete
DELETE {{KorID.API_HostAddress}}/api/Organizations/1
Accept: application/json

###
# Applications
GET {{KorID.API_HostAddress}}/api/Applications
Accept: application/json

###
# Applications - Get by id
GET {{KorID.API_HostAddress}}/api/Applications/1
Accept: application/json

###
# Applications - Create
POST {{KorID.API_HostAddress}}/api/Applications
Content-Type: application/json
Accept: application/json

{
  "name": "My App",
  "clientId": "my-app-client-id",
  "clientSecret": "super-secret",
  "redirectUri": "https://app.example.com/callback",
  "organizationId": 1
}

###
# Applications - Update
PUT {{KorID.API_HostAddress}}/api/Applications/1
Content-Type: application/json
Accept: application/json

{
  "id": 1,
  "name": "My App (Updated)",
  "clientId": "my-app-client-id",
  "clientSecret": "new-secret",
  "redirectUri": "https://app.example.com/callback",
  "organizationId": 1
}

###
# Applications - Delete
DELETE {{KorID.API_HostAddress}}/api/Applications/1
Accept: application/json

###
# Roles
