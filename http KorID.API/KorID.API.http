Accept: application/json

###
# Roles - Get by id
GET {{KorID.API_HostAddress}}/api/Roles/1
Accept: application/json

###
# Roles - Create
POST {{KorID.API_HostAddress}}/api/Roles
Content-Type: application/json
Accept: application/json

{
  "name": "Admin",
  "resourceGroup": "users"
}

###
# Roles - Update
PUT {{KorID.API_HostAddress}}/api/Roles/1
Content-Type: application/json
Accept: application/json

{
  "id": 1,
  "name": "Administrator",
  "resourceGroup": "users"
}

###
# Roles - Delete
DELETE {{KorID.API_HostAddress}}/api/Roles/1
Accept: application/json

###
# UserApplications (many-to-many)
GET {{KorID.API_HostAddress}}/api/UserApplications
Accept: application/json

###
# UserApplications - Get by userId and applicationId
GET {{KorID.API_HostAddress}}/api/UserApplications/1/2
Accept: application/json

###
# UserApplications - Create
POST {{KorID.API_HostAddress}}/api/UserApplications
Content-Type: application/json
Accept: application/json

{
  "userId": 1,
  "applicationId": 2,
  "grantedAt": "2026-01-07T00:00:00Z"
}

###
# UserApplications - Update
PUT {{KorID.API_HostAddress}}/api/UserApplications/1/2
Content-Type: application/json
Accept: application/json

{
  "userId": 1,
  "applicationId": 2,
  "grantedAt": "2026-01-08T00:00:00Z"
}

###
# UserApplications - Delete
DELETE {{KorID.API_HostAddress}}/api/UserApplications/1/2
Accept: application/json